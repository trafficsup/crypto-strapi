      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "meta_description": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "faq": {
      "type": "json"
    },
    "related_casinos": {
      "type": "json"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "draft",
        "review",
        "published"
      ],
      "default": "draft"
    }
  }
}